# ============================================================
# Backend Environment Variables — copy, fill in, and set in
# your Railway (or other host) environment variable dashboard.
# NEVER commit the actual .env file with real secrets.
# ============================================================

# --- Database (Railway PostgreSQL plugin provides this automatically) ---
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# --- Security (REQUIRED — generate with: openssl rand -hex 32) ---
SECRET_KEY=replace-with-64-char-hex-string-from-openssl-rand-hex-32

# --- Token expiry (these defaults are fine for production) ---
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# PASSWORD_RESET_EXPIRE_MINUTES=30
# REMEMBER_LOGIN_EXPIRE_DAYS=30
# LOGIN_VERIFICATION_EXPIRE_MINUTES=10
# LOGIN_VERIFICATION_MAX_ATTEMPTS=5
# LOGIN_VERIFICATION_RESEND_COOLDOWN_SECONDS=30

# --- Session behavior ---
# Set to false in production so deploys don't log everyone out
INVALIDATE_TOKENS_ON_RESTART=false

# --- Frontend URL (used in auth emails) ---
# Set to your Vercel deployment URL, e.g. https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# --- CORS (comma-separated list of allowed origins) ---
# Add your Vercel production URL and any preview URLs you need
CORS_ORIGINS=https://your-app.vercel.app

# --- Cookies (MUST be true in production over HTTPS) ---
COOKIE_SECURE=true
# Use "none" for cross-domain cookies (Vercel frontend + Railway backend)
COOKIE_SAMESITE=none\n